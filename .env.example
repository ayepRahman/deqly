# ===========================================
# Deqly Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# Run `pnpm dlx convex dev` to auto-populate CONVEX_DEPLOYMENT and VITE_CONVEX_URL.

# --- Convex ---
CONVEX_DEPLOYMENT=             # Auto-populated by `convex dev` (e.g., dev:your-animal-123)
VITE_CONVEX_URL=               # Auto-populated by `convex dev` (e.g., https://your-animal-123.convex.cloud)
VITE_CONVEX_SITE_URL=          # Convex HTTP actions URL (e.g., https://your-animal-123.convex.site)

# --- Better Auth ---
BETTER_AUTH_SECRET=            # Generate with: openssl rand -base64 32
SITE_URL=                      # Your app's base URL (e.g., http://localhost:3000 for dev, https://app.deqly.com for prod)

# --- Resend (email) ---
RESEND_API_KEY=                # Get from https://resend.com/api-keys
EMAIL_FROM=Deqly <noreply@deqly.com>

# --- Image storage ---
# Images are uploaded to Convex file storage. No additional env vars required.
